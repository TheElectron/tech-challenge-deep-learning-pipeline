{
  "title": "LSTM Stock Predictor",
  "uid": "lstm-stock-predictor",
  "timezone": "browser",
  "refresh": "15s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (path)",
          "legendFormat": "{{path}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "title": "Error Rate (5xx/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx errors",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "id": 3,
      "title": "Request Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{path=\"/predict\"}[5m])) by (le))",
          "legendFormat": "p50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{path=\"/predict\"}[5m])) by (le))",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{path=\"/predict\"}[5m])) by (le))",
          "legendFormat": "p99",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": "Champion Model RMSE",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "model_rmse",
          "legendFormat": "RMSE",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Predictions by Ticker",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(increase(predictions_total[1h])) by (ticker)",
          "legendFormat": "{{ticker}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "title": "Predicted Price Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(prediction_value_usd_bucket[10m])) by (le))",
          "legendFormat": "median predicted price",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    }
  ]
}
